# Template for local-only bundle values.
# Copy this file to "databricks.local.yml" and fill in your own values.
# databricks.local.yml is git-ignored and stays only on your machine.
targets:
  dev:
    workspace:
      host: https://<your-workspace>.cloud.databricks.com
  prod:
    workspace:
      host: https://<your-workspace>.cloud.databricks.com

variables:
  workspace_user:
    default: your-email@example.com
  kaggle_api_token:
    default: your-token
